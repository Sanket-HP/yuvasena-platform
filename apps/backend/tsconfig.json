{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",

    "target": "ES2022",

    "declaration": false,
    "declarationMap": false,
    "composite": false,

    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,

    "allowJs": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "baseUrl": ".",

    "paths": {
      "@/*": ["src/*"],
      "@yuvasena/shared": [
        "../../packages/shared/dist"
      ]
    },

    "outDir": "./dist"
  },

  "include": [
    "src/**/*",
    "prisma/**/*"
  ]
}